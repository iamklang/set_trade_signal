#!/usr/bin/env bash
# morning_scan — pre-market ready list: run scan_ready.py before the SET open.
# Sends the DIP READY / BRK READY / ALMOST list to LINE so the trader knows
# what to watch during the session.  Scheduled by launchd at 08:30 weekdays.
set -euo pipefail

PROJ="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV="$HOME/.venvs/trading-dr"
PY="$VENV/bin/python"

if [ ! -x "$PY" ] || ! "$PY" -c "import pandas" >/dev/null 2>&1; then
  echo "venv missing/broken at $VENV — (re)creating it …" >&2
  rm -rf "$VENV"
  python3 -m venv "$VENV"
  "$VENV/bin/pip" install -q --upgrade pip
  "$VENV/bin/pip" install -q yfinance pandas numpy exchange-calendars
fi

cd "$PROJ"
echo "===== morning_scan @ $(date '+%Y-%m-%d %H:%M') ====="
"$PY" scan_ready.py "$@"
